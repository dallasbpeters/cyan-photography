# Neon — paste from https://console.neon.tech (use pooled connection for serverless)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# API auth (min 16 characters in production)
JWT_SECRET=your-long-random-secret-here

# Optional: enables POST /api/auth/register with body { email, password, setupSecret }
ADMIN_SETUP_SECRET=

# One-time seed (pnpm db:seed)
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=

# Local dev only: Vite runs on 5173; point API proxy at vercel dev (default 3000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# If the frontend and API are on different origins, set the API origin (usually empty on Vercel)
# VITE_API_BASE_URL=
