{
  "name": "cyan-photography",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=5173 --host=0.0.0.0",
    "dev:local": "concurrently -k -n api,web -c cyan,magenta \"vercel dev --listen 3000\" \"wait-on tcp:127.0.0.1:3000 && cross-env VITE_USE_LOCAL_API=1 vite --port=5173 --host=0.0.0.0\"",
    "dev:vercel": "vercel dev --listen 3000",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:add-user": "tsx scripts/add-user.ts",
    "db:verify-login": "tsx scripts/verify-login.ts",
    "vercel:blob:create": "vercel blob create-store",
    "vercel:env:pull": "vercel env pull .env.development.local"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@cesdk/cesdk-js": "^1.71.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/blob": "^2.3.2",
    "@vercel/node": "^5.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "iconoir-react": "^7.11.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.11",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "pg": "^8.14.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vercel": "^50.37.3",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  }
}
